# Nombre de la aplicacion que se expone en logs y health checks.
APP_NAME=tienda-go
# Entorno actual. Aqui sirve para diferenciar desarrollo de otros ambientes.
APP_ENV=development
# Direccion HTTP donde escucha la API.
APP_ADDR=:8080
# En plataformas como Render, si APP_ADDR no existe, la app usa PORT automaticamente.
# PORT=10000
# Tiempo maximo para leer una peticion completa.
APP_READ_TIMEOUT=5s
# Tiempo maximo para escribir una respuesta.
APP_WRITE_TIMEOUT=10s
# Tiempo maximo para apagar el servidor de forma ordenada.
APP_SHUTDOWN_WAIT=10s
# Duracion de vida de los tokens de sesion.
AUTH_TOKEN_TTL=12h
# Limite para considerar un producto con poco stock en el dashboard.
LOW_STOCK_LIMIT=5
# Moneda por defecto del negocio.
APP_CURRENCY=COP
# Driver de persistencia: memory o mysql.
STORE_DRIVER=memory
# DSN de MySQL. Ejemplo:
# root:secret@tcp(127.0.0.1:3306)/tienda_go?charset=utf8mb4
MYSQL_DSN=
# Si esta en true, la app crea las tablas necesarias al arrancar.
MYSQL_AUTO_MIGRATE=true
# Si esta en true, crea datos demo cuando la base este vacia.
APP_SEED_ON_START=true

# Conexiones del port partner-users.
# Puedes usar DSN directos...
PARTNER_USERS_APP_DSN=
PARTNER_USERS_PROD_DSN=

# ...o variables separadas al estilo Laravel, que la app convertira a DSN.
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

PROD_DB_HOST=
PROD_DB_PORT=3306
PROD_DB_DATABASE=
PROD_DB_USERNAME=
PROD_DB_PASSWORD=

# Credenciales de la API externa del partner.
PARTNER_API_USER=
PARTNER_API_PASS=
PARTNER_API_BASE_URL=https://nuplin.com/partner/api/
PARTNER_LOGIN_BASE_URL=https://nuplin.com
PARTNER_API_TIMEOUT=20s
PARTNER_API_SKIP_TLS_VERIFY=true
